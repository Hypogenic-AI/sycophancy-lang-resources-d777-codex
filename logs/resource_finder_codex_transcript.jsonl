{"type":"item.started","item":{"id":"item_90","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate && python - <<'PY'\nimport gzip, json, csv\nfrom pathlib import Path\nroot = Path('datasets')\n# MKQA sample\nmkqa_path = root / 'mkqa' / 'mkqa.jsonl.gz'\nsamples = []\nwith gzip.open(mkqa_path, 'rt', encoding='utf-8') as f:\n    for i, line in enumerate(f):\n        if i >= 3: break\n        ex = json.loads(line)\n        samples.append({\n            'example_id': ex['example_id'],\n            'query': ex['query'],\n            'queries': {k: ex['queries'][k] for k in ['en','de','ar','zh_cn']},\n            'answers': {k: ex['answers'][k] for k in ['en','de']},\n        })\n(root / 'mkqa' / 'samples.json').write_text(json.dumps(samples, ensure_ascii=False, indent=2), encoding='utf-8')\n# BullshitBench sample from first technique questions\nfor fname in ['questions.json','questions.v2.json']:\n    data = json.loads((root / 'bullshitbench' / fname).read_text())\n    out = []\n    for tech in data['techniques'][:2]:\n        for q in tech['questions'][:2]:\n            out.append({'technique': tech['technique'], **q})\n    (root / 'bullshitbench' / f'{fname}.sample.json').write_text(json.dumps(out, ensure_ascii=False, indent=2), encoding='utf-8')\n# ELEPHANT sample manifest from copied CSVs\nmanifest = {}\nfor csv_path in sorted((root / 'elephant').glob('*.csv')):\n    with open(csv_path, newline='', encoding='utf-8') as f:\n        reader = csv.DictReader(f)\n        rows = []\n        for i, row in enumerate(reader):\n            rows.append(row)\n            if i >= 1: break\n    manifest[csv_path.name] = {'columns': list(rows[0].keys()) if rows else [], 'sample_rows': rows}\n(root / 'elephant' / 'samples.json').write_text(json.dumps(manifest, ensure_ascii=False, indent=2), encoding='utf-8')\nprint('Wrote sample artifacts.')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
